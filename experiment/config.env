# Shared experiment parameters — both classical and PQC must use these values.
PAGE_SIZE_KB=150
PAGE_FILE=page-150k.bin
ITERATIONS=60
SIM_LATENCY_MS=50
PORT=7443
MEASURE_TOOL=curl
WARMUP=0

# Classical TLS 1.3 (baseline)
CLASSICAL_GROUPS=X25519
CLASSICAL_SIGALGS=

# PQC-only TLS 1.3
PQC_GROUPS=MLKEM768
PQC_SIGALGS=mldsa65
